# =============================================================================
# AAMAPP — Production Environment Template
# Salin file ini: cp .env.example .env
# Isi SEMUA nilai sebelum deploy. Jangan commit .env ke Git.
# =============================================================================

# --- Database PostgreSQL ---
POSTGRES_DB=aamapp
POSTGRES_USER=aamapp
POSTGRES_PASSWORD=GANTI_DENGAN_PASSWORD_KUAT_32CHAR

# --- Admin seed (hanya dipakai saat tabel users KOSONG / fresh deploy) ---
ADMIN_NAME=Administrator
ADMIN_EMAIL=admin@sekolah.sch.id
ADMIN_PASSWORD=GANTI_PASSWORD_ADMIN_KUAT

# --- Tahun Ajaran awal (opsional, auto-detect jika kosong) ---
# Format: YYYY/YYYY
# SEED_TA_NAMA=2025/2026
# SEED_TA_SEMESTER=1

# --- Google Identity Services (opsional) ---
GOOGLE_CLIENT_ID=

# --- CORS Origins (wajib diisi di production) ---
# CSV domain: https://domain1.com,https://domain2.com
ALLOWED_ORIGINS=https://DOMAIN_ANDA.sch.id

# --- Sesi ---
SESSION_IDLE_MINUTES=60
SESSION_ABSOLUTE_HOURS=24

# --- Web ---
WEB_PORT=80

# --- Timezone ---
TZ=Asia/Jakarta