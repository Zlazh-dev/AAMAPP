# =========================================================================
# AAMAPP — Ekosistem Sekolah SMP IT Asy-Syadzili
# Salin file ini menjadi .env lalu sesuaikan nilainya
# =========================================================================
# Audit: semua process.env di backend/src tercatat di sini (2026-07-16)
# Penanda: [WAJIB] = harus diisi, [OPSIONAL] = boleh kosong punya default
# =========================================================================

# --- Database PostgreSQL [WAJIB] ---
# Nama database yang dibuat saat container db pertama kali start
POSTGRES_DB=aamapp
# User database
POSTGRES_USER=aamapp
# Password database — GANTI di produksi! (default di bawah hanya untuk dev)
POSTGRES_PASSWORD=aamapp_dev_change_me

# --- Host & port database [OPSIONAL — biasanya di-set via compose, bukan .env] ---
# Default: db (nama service di docker-compose) / 5432 (port default PostgreSQL)
# DB_HOST=db
# DB_PORT=5432

# --- Admin seed [WAJIB] ---
# Akun admin dibuat otomatis saat tabel users kosong (bootstrap seed)
# GANTI password di produksi!
ADMIN_NAME=Administrator
ADMIN_EMAIL=admin@aamapp.sch.id
ADMIN_PASSWORD=admin12345

# --- Google Identity Services [OPSIONAL] ---
# Client ID untuk login Google (GIS ID-token flow)
# Kosongkan bila belum punya. Buat di Google Cloud Console →
#   Credentials → OAuth Client ID → Application type: Web
# Authorized JavaScript origins: http://localhost (+ domain produksi nanti)
# Akun Google biasa (gratis) cukup — tidak perlu Workspace.
GOOGLE_CLIENT_ID=

# --- Sesi [OPSIONAL] ---
# Idle timeout: berapa menit tanpa aktivitas sebelum sesi berakhir
# Default: 60 (1 jam)
SESSION_IDLE_MINUTES=60
# Absolute timeout: berapa jam sesi hidup sejak login (apapun aktivitasnya)
# Default: 24 (1 hari)
SESSION_ABSOLUTE_HOURS=24

# --- Upload root [OPSIONAL — di-set via compose environment] ---
# Direktori penyimpanan file upload (foto guru/siswa, dsb)
# Default di container: /data/uploads (di-set via docker-compose.yml)
# UPLOAD_ROOT=/data/uploads

# --- Web [OPSIONAL] ---
# Port frontend yang dipetakan ke host
# Default: 80
WEB_PORT=80

# --- Timezone [OPSIONAL] ---
# Zona waktu untuk container dan database (WIB = Asia/Jakarta)
# Default: Asia/Jakarta
TZ=Asia/Jakarta